{
  "name": "immigration-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "bun apps/server/src/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "mobile": "bun run --cwd apps/mobile start",
    "mobile:local": "bun run --cwd apps/mobile start:local",
    "server": "bun run --cwd apps/server dev",
    "typecheck": "bun --workspaces run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~6.0.3"
  },
  "trustedDependencies": [
    "heroui-pro",
    "@heroui-pro/react",
    "heroui-native-pro"
  ]
}
