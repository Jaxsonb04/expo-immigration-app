{
  "name": "@immigration/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "test": "bun test ./src",
    "auth:migrate": "bunx @better-auth/cli migrate --config src/auth-config.ts --yes",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-auth": "1.6.20",
    "hono": "^4.12.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "8.15.6",
    "bun-types": "^1.3.14"
  }
}
