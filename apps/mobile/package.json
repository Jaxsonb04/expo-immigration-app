{
  "name": "@immigration/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --tunnel",
    "start:local": "expo start --dev-client --localhost --port 8082",
    "start:go": "expo start",
    "android": "expo run:android",
    "ios": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 RUBYOPT=-rlogger expo run:ios --port 8082",
    "ios:prebuild": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 RUBYOPT=-rlogger expo prebuild --platform ios",
    "ios:run": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 RUBYOPT=-rlogger expo run:ios --port 8082",
    "test": "bun test ./src",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo/metro-runtime": "~56.0.13",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@immigration/shared": "workspace:*",
    "@internationalized/date": "^3.12.0",
    "@internationalized/number": "^3.6.6",
    "@shopify/react-native-skia": "2.6.2",
    "expo": "~56.0.5",
    "expo-constants": "~56.0.16",
    "expo-font": "~56.0.5",
    "expo-linking": "~56.0.12",
